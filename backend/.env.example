# Server
PORT=8787
FRONTEND_DIST_DIR=
SERVER_READ_HEADER_TIMEOUT_SEC=10
SERVER_READ_TIMEOUT_SEC=30
SERVER_WRITE_TIMEOUT_SEC=120

# PostgreSQL
PG_DSN=postgres://resumecraft:resumecraft@localhost:5432/resumecraft?sslmode=disable

# Auth
AUTH_ENABLED=true
AUTH_JWT_SECRET=change-this-in-production
AUTH_ACCESS_TTL_MIN=120
AUTH_REFRESH_TTL_MIN=43200

# PDF Render
PDF_RENDER_TIMEOUT_SEC=60
PDF_VIEWPORT_WIDTH=794
PDF_VIEWPORT_HEIGHT=1123
PDF_DEVICE_SCALE_FACTOR=1
PDF_PAPER_WIDTH_INCH=8.27
PDF_PAPER_HEIGHT_INCH=11.69
PDF_SCALE=1

# Chromium launch flags
CHROMIUM_HEADLESS=true
CHROMIUM_DISABLE_GPU=true
CHROMIUM_NO_SANDBOX=true
CHROMIUM_DISABLE_SETUID_SANDBOX=true
